# Copy to `.env.local` (gitignored) and fill in the values you want
# to enable. Every var is optional — the demo gracefully degrades
# when something isn't set (toast hint on the export side, browser
# blob URLs on the upload side).

# Where uploaded videos should be POSTed. The endpoint must accept a
# multipart/form-data body with a `file` field and reply with JSON
# `{ "url": "https://..." }` — that URL is what the editor stores in
# the Project's `sources[].url` field and what ffmpeg later opens for
# export. Leave blank to skip server upload entirely; the demo will
# fall back to `URL.createObjectURL(file)` which gives back a `blob:`
# URL playable in the browser only (can't be exported by the backend
# unless your backend can resolve `blob:` URLs — it can't).
VITE_UPLOAD_ENDPOINT=

# Your TS / Go backend export endpoints. The demo's sidebar lets the
# user pick which one to use; only the ones you configure here show
# up in the dropdown. Both blank → export button is disabled with a
# toast hint telling the user to configure a backend.
VITE_BACKEND_TS_URL=
VITE_BACKEND_GO_URL=

# Public URL prefix when building for GitHub Pages. Leave empty for
# local dev; the deploy workflow injects `/AiCut/` automatically.
VITE_BASE_PATH=
