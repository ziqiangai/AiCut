{
  "name": "@aicut/core",
  "version": "0.7.3",
  "description": "Framework-agnostic core for the AiCut video editor — canvas timeline, data model, pluggable PlaybackEngine (HTML5 / Canvas / WebCodecs), plus opt-in 3D lighting picker.",
  "license": "MIT",
  "author": "ziqiang <ziqiangytu@gmail.com>",
  "homepage": "https://github.com/ziqiangai/AiCut#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziqiangai/AiCut.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ziqiangai/AiCut/issues"
  },
  "keywords": [
    "video-editor",
    "video-editing",
    "timeline",
    "timeline-editor",
    "nle",
    "video-cutter",
    "video-clip",
    "canvas",
    "ffmpeg",
    "video",
    "editor",
    "mp4",
    "component",
    "framework-agnostic",
    "capcut",
    "premiere",
    "final-cut",
    "davinci",
    "imovie",
    "veed",
    "filmora",
    "lighting",
    "three.js",
    "ai-relighting"
  ],
  "type": "module",
  "sideEffects": [
    "./styles/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lighting": {
      "types": "./dist/lighting/index.d.ts",
      "import": "./dist/lighting/index.js",
      "require": "./dist/lighting/index.cjs"
    },
    "./lighting-v3": {
      "types": "./dist/lighting-v3/index.d.ts",
      "import": "./dist/lighting-v3/index.js",
      "require": "./dist/lighting-v3/index.cjs"
    },
    "./webcodecs": {
      "types": "./dist/playback/webcodecs/index.d.ts",
      "import": "./dist/playback/webcodecs/index.js",
      "require": "./dist/playback/webcodecs/index.cjs"
    },
    "./styles.css": "./styles/theme.css",
    "./lighting-v3.css": "./styles/lighting-v3.css"
  },
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mp4box": "^2.4.1",
    "three": "^0.159.0"
  },
  "devDependencies": {
    "@types/three": "^0.159.0",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
