{
  "name": "@aicut/core",
  "version": "0.1.1",
  "description": "Framework-agnostic core for the AiCut video editor — canvas timeline, data model, HTML5 playback engine.",
  "license": "MIT",
  "author": "ziqiang <ziqiangytu@gmail.com>",
  "homepage": "https://github.com/ziqiangai/AiCut#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziqiangai/AiCut.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ziqiangai/AiCut/issues"
  },
  "keywords": [
    "video-editor",
    "video-editing",
    "timeline",
    "timeline-editor",
    "nle",
    "video-cutter",
    "video-clip",
    "canvas",
    "ffmpeg",
    "video",
    "editor",
    "mp4",
    "component",
    "framework-agnostic",
    "capcut",
    "premiere",
    "final-cut",
    "davinci",
    "imovie",
    "veed",
    "filmora"
  ],
  "type": "module",
  "sideEffects": ["./styles/*.css"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/theme.css"
  },
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
