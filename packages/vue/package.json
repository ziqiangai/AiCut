{
  "name": "@aicut/vue",
  "version": "0.1.1",
  "description": "Vue 3 wrapper for the AiCut video editor — thin declarative shell over @aicut/core.",
  "license": "MIT",
  "author": "ziqiang <ziqiangytu@gmail.com>",
  "homepage": "https://github.com/ziqiangai/AiCut#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziqiangai/AiCut.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/ziqiangai/AiCut/issues"
  },
  "keywords": [
    "video-editor",
    "video-editing",
    "vue",
    "vue3",
    "vue-component",
    "timeline",
    "timeline-editor",
    "nle",
    "video-cutter",
    "video-clip",
    "canvas",
    "video",
    "editor",
    "mp4",
    "component",
    "capcut",
    "premiere",
    "final-cut",
    "davinci",
    "imovie",
    "veed",
    "filmora"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly -p tsconfig.json --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@aicut/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
